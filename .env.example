# BeyondSight Environment Variables
# Copy this file to .env and fill in your API keys.

# Groq Cloud API Key (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama Host (Optional, defaults to http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Twitter/X Bearer Token (https://developer.twitter.com — Optional, for social media seeding)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit API Credentials (https://www.reddit.com/prefs/apps — Optional, for social media seeding)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Optional raw HTML/JS analytics snippet injected by deployment environments.
# Leave empty for local/dev runs.
MASSIVE_ANALYTICS_SNIPPET=
