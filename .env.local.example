# BeyondSight Streamlit Environment Variables (.env.local)
# This file is used by Streamlit and mounted into the Docker container.
# Copy .env.example to .env.local and fill in your API keys.

# Groq Cloud API Key
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama Host (Optional, defaults to http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Twitter/X Bearer Token (Optional, for social media seeding)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit API Credentials (Optional, for social media seeding)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
